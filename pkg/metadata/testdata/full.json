{
  "metadata": {
    "instance": {
      "hostname": "example-host-001",
      "crypted_root_password": "$6$salt$hash",
      "ssh_keys": ["ssh-ed25519 AAAA... root@bastion"],
      "console": {
        "tty": "ttyS1",
        "baud": 115200
      },
      "users": [
        {
          "username": "ubuntu",
          "crypted_password": "$6$salt$hash",
          "ssh_authorized_keys": ["ssh-ed25519 AAAA... ubuntu@bastion"],
          "sudo": true,
          "shell": "/bin/bash"
        }
      ],
      "sshd": {
        "permit_root_login": "prohibit-password",
        "password_authentication": false
      },
      "operating_system_version": {
        "distro": "ubuntu",
        "os_codename": "noble",
        "os_slug": "ubuntu_24_04",
        "version": "24.04"
      },
      "storage": {
        "disks": [
          {
            "device": "/dev/sda",
            "wipe_table": true,
            "partitions": [
              {"label": "EFI",   "number": 1, "size": 524288},
              {"label": "LINUX", "number": 2, "size": 0}
            ]
          },
          {
            "device": "/dev/sdb",
            "wipe_table": true,
            "partitions": [
              {"label": "EFI",   "number": 1, "size": 524288},
              {"label": "LINUX", "number": 2, "size": 0}
            ]
          }
        ],
        "raid": [
          {
            "name": "/dev/md0",
            "level": "1",
            "devices": ["/dev/sda2", "/dev/sdb2"]
          }
        ],
        "volume_groups": [
          {
            "name": "vg0",
            "physical_volumes": ["/dev/md0"],
            "logical_volumes": [
              {"name": "root",   "size": 42949672960},
              {"name": "var",    "size": 42949672960},
              {"name": "home",   "size": 10737418240},
              {"name": "docker", "size": 0}
            ]
          }
        ],
        "filesystems": [
          {
            "mount": {
              "create": {"options": ["-F", "32", "-n", "EFI_SDA"]},
              "device": "/dev/sda1",
              "format": "vfat",
              "point": "/boot/efi"
            }
          },
          {
            "mount": {
              "create": {"options": ["-F", "32", "-n", "EFI_SDB"]},
              "device": "/dev/sdb1",
              "format": "vfat",
              "point": "/boot/efi2"
            }
          },
          {
            "mount": {
              "create": {"options": ["-L", "ROOT"]},
              "device": "/dev/vg0/root",
              "format": "ext4",
              "point": "/"
            }
          },
          {
            "mount": {
              "create": {"options": ["-L", "VAR"]},
              "device": "/dev/vg0/var",
              "format": "ext4",
              "point": "/var"
            }
          },
          {
            "mount": {
              "create": {"options": ["-L", "HOME"]},
              "device": "/dev/vg0/home",
              "format": "ext4",
              "point": "/home"
            }
          },
          {
            "mount": {
              "create": {"options": ["-L", "DOCKER"]},
              "device": "/dev/vg0/docker",
              "format": "ext4",
              "point": "/var/lib/docker"
            }
          }
        ]
      }
    },
    "facility": {
      "facility_code": "eu-lon1",
      "plan_slug": "bare-metal"
    }
  }
}
